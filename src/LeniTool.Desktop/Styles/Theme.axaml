<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <Color x:Key="SystemAccentColor">#6F8092</Color>
    <Color x:Key="SystemAccentColorDark1">#5C6A79</Color>
    <Color x:Key="SystemAccentColorDark2">#495562</Color>
    <Color x:Key="SystemAccentColorDark3">#343D47</Color>
    <Color x:Key="SystemAccentColorLight1">#8597A9</Color>
    <Color x:Key="SystemAccentColorLight2">#99A8B7</Color>
    <Color x:Key="SystemAccentColorLight3">#B0BCC8</Color>

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Offset="0" Color="#0C0E12" />
      <GradientStop Offset="0.55" Color="#10141A" />
      <GradientStop Offset="1" Color="#141A21" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#15191F" />
    <SolidColorBrush x:Key="CardBackgroundAltBrush" Color="#1A1F26" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#2A3038" />
    <SolidColorBrush x:Key="CardBorderSoftBrush" Color="#21262E" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E7EBF2" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#AFB7C3" />
    <SolidColorBrush x:Key="TextSubtleBrush" Color="#838C98" />

    <SolidColorBrush x:Key="AccentBrush" Color="#6F8092" />
    <SolidColorBrush x:Key="AccentBrushStrong" Color="#8094A9" />
    <SolidColorBrush x:Key="AccentBrushSoft" Color="#202730" />

    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#12161C" />
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#2C333D" />
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#1A1F26" />
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="#3B4654" />
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#181D23" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#232A33" />

    <SolidColorBrush x:Key="BadgeNeutralBg" Color="#242B34" />
    <SolidColorBrush x:Key="BadgeNeutralFg" Color="#D4DCE7" />
    <SolidColorBrush x:Key="BadgeSuccessBg" Color="#1A3026" />
    <SolidColorBrush x:Key="BadgeSuccessFg" Color="#B7E7CC" />
    <SolidColorBrush x:Key="BadgeWarningBg" Color="#352C1C" />
    <SolidColorBrush x:Key="BadgeWarningFg" Color="#E6C895" />
    <SolidColorBrush x:Key="BadgeDangerBg" Color="#381E24" />
    <SolidColorBrush x:Key="BadgeDangerFg" Color="#E9C0C8" />

    <SolidColorBrush x:Key="ListHeaderBg" Color="#11151A" />
    <SolidColorBrush x:Key="ListRowHoverBg" Color="#1A2027" />
    <SolidColorBrush x:Key="ListRowSelectedBg" Color="#202730" />
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="TextBlock.h1">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.h2">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.subtle">
    <Setter Property="Foreground" Value="{DynamicResource TextSubtleBrush}" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="15" />
    <Setter Property="BoxShadow" Value="0 16 36 0 #14000000" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource AccentBrushStrong}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrushStrong}" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,9" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource ControlHoverBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
  </Style>

  <Style Selector="Border.badge">
    <Setter Property="Background" Value="{DynamicResource BadgeNeutralBg}" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,4" />
  </Style>

  <Style Selector="Border.badge > TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource BadgeNeutralFg}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.badge.success">
    <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
  </Style>

  <Style Selector="Border.badge.success > TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
  </Style>

  <Style Selector="Border.badge.warning">
    <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
  </Style>

  <Style Selector="Border.badge.warning > TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
  </Style>

  <Style Selector="Border.badge.danger">
    <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
  </Style>

  <Style Selector="Border.badge.danger > TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
  </Style>

  <Style Selector="Border.listHeader">
    <Setter Property="Background" Value="{DynamicResource ListHeaderBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,8" />
  </Style>

  <Style Selector="ListBox.filesList">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ListBox.filesList ListBoxItem">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Margin" Value="0,2" />
  </Style>

  <Style Selector="ListBox.filesList ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ListRowHoverBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
  </Style>

  <Style Selector="ListBox.filesList ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ListRowSelectedBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
  </Style>

  <Style Selector="ListBox.filesList ListBoxItem /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <Style Selector="ListBox.logList">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
  </Style>

  <Style Selector="ListBox.logList ListBoxItem /template/ ContentPresenter">
    <Setter Property="Padding" Value="10,7" />
  </Style>

  <Style Selector="Border.outputItem">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="10,8" />
    <Setter Property="Margin" Value="0,0,0,6" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>

  <Style Selector="TextBox:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
  </Style>

  <Style Selector="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="MenuItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource MenuHoverBrush}" />
  </Style>

  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource CardBorderSoftBrush}" />
  </Style>

  <Style Selector="Border.dropOverlayBox">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="18" />
  </Style>

  <Style Selector="Border.dropOverlayBox.accept">
    <Setter Property="BorderBrush" Value="#2EE59D" />
  </Style>

  <Style Selector="Border.dropOverlayBox.reject">
    <Setter Property="BorderBrush" Value="#FF5C77" />
  </Style>

  <Style Selector="Border.settingsBackdrop">
    <Setter Property="Background" Value="#72000000" />
    <Setter Property="Padding" Value="24" />
  </Style>

  <Style Selector="Border.settingsModal">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="Padding" Value="20" />
    <Setter Property="BoxShadow" Value="0 22 48 0 #24000000" />
  </Style>

  <Style Selector="Border.settingsSection">
    <Setter Property="Background" Value="{DynamicResource CardBackgroundAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="TabControl.settingsTabs TabItem">
    <Setter Property="Margin" Value="0,0,8,0" />
  </Style>

  <Style Selector="TabControl.settingsTabs TabItem /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource CardBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="12,8" />
  </Style>

  <Style Selector="TabControl.settingsTabs TabItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrushSoft}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SelectionBorderBrush}" />
  </Style>

</Styles>
